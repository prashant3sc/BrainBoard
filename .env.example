# ─────────────────────────────────────────────────────────────────────────────
#  BrainBoard – Environment Variables
#
#  1. Copy this file:   cp .env.example .env   (or duplicate in Windows)
#  2. Fill in DB_PASSWORD with the value your team lead shares with you
#  3. Never commit .env to git
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (runs inside Docker) ──────────────────────────────────────────
# DB_HOST must stay as "db" — that is the Docker container name
DB_NAME=jira_main
DB_USER=postgres
DB_PASSWORD=your_shared_password_here
DB_HOST=db
DB_PORT=5432

# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=django-insecure-change-this-to-a-long-random-string
DEBUG=True

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
